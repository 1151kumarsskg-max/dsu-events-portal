<script type="ac2791edb1fdc6877e222d1b-text/javascript">
document.addEventListener("DOMContentLoaded", function () {

  const track = document.querySelector(".evc-track");
  const slides = document.querySelectorAll(".evc-slide");
  const nextBtn = document.querySelector(".evc-next");
  const prevBtn = document.querySelector(".evc-prev");

  let index = 1;
  let slideWidth = slides[0].clientWidth;
  let interval;

  const firstClone = slides[0].cloneNode(true);
  const lastClone = slides[slides.length - 1].cloneNode(true);

  firstClone.id = "evc-first-clone";
  lastClone.id = "evc-last-clone";

  track.appendChild(firstClone);
  track.insertBefore(lastClone, slides[0]);

  const allSlides = document.querySelectorAll(".evc-slide");

  track.style.transform = `translateX(-${slideWidth * index}px)`;

  function moveSlide() {
    track.style.transition = "transform 0.6s ease-in-out";
    track.style.transform = `translateX(-${slideWidth * index}px)`;
  }

  nextBtn.addEventListener("click", () => {
    if (index >= allSlides.length - 1) return;
    index++;
    moveSlide();
  });

  prevBtn.addEventListener("click", () => {
    if (index <= 0) return;
    index--;
    moveSlide();
  });

  track.addEventListener("transitionend", () => {

    if (allSlides[index].id === "evc-first-clone") {
      track.style.transition = "none";
      index = 1;
      track.style.transform = `translateX(-${slideWidth * index}px)`;
    }

    if (allSlides[index].id === "evc-last-clone") {
      track.style.transition = "none";
      index = allSlides.length - 2;
      track.style.transform = `translateX(-${slideWidth * index}px)`;
    }

  });

  function autoSlide() {
    interval = setInterval(() => {
      nextBtn.click();
    }, 7000);
  }

  autoSlide();

});
</script>


