<style>
/* ===============================
   EVC - Event Carousel Styles
================================ */

.evc-section {
  width: 100%;
  padding: 60px 0;
  background: #f4f6f9;
  overflow: hidden;
}
.evc-slide {
  min-height: 412px;
}

/* Main Section Heading */
.evc-main-heading {
  text-align: center;
  font-size: 36px;
  margin-bottom: 40px;
  font-weight: 700;
  letter-spacing: 1px;
  color: #222;
  position: relative;
}

.evc-main-heading:after {
  content: "";
  width: 60px;
  height: 3px;
  background: #007bff;
  display: block;
  margin: 12px auto 0;
  border-radius: 2px;
}

.evc-wrapper {
  max-width: 1200px;
  margin: auto;
  position: relative;
  overflow: hidden;
}

.evc-track {
  display: flex;
  transition: transform 1.5s ease-in-out;
}

.evc-slide {
  min-width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  border-radius: 12px;
  overflow: hidden;
border: 1px solid #bfdbfe;
}

.evc-content {
  width: 50%;
  padding: 60px;
}

.evc-content h2 {
  font-size: 28px;
  margin-bottom: 15px;
}

.evc-content p {
  font-size: 16px;
  color: #555;
  margin-bottom: 20px;
  line-height: 1.6;
}

.evc-btn {
  display: inline-block;
  padding: 10px 24px;
  background: #007bff;
  color: #fff;
  text-decoration: none;
  border-radius: 5px;
  transition: 0.3s ease;
}

.evc-btn:hover {
  background: #0056b3;
color: white;
}

.evc-image {
  width: 50%;
  height:100%;
  background-size: cover;
 /* background-position: center; */
}

/* Arrows */
.evc-prev,
.evc-next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(0,0,0,0.6);
  color: #fff;
  border: none;
  padding: 14px 18px;
  cursor: pointer;
  font-size: 18px;
  border-radius: 50%;
  z-index: 10;
}

.evc-prev:hover,
.evc-next:hover {
  background: rgba(0,0,0,0.9);
}

.evc-prev { left: 15px; }
.evc-next { right: 15px; }

/* Responsive */
@media (max-width: 768px) {

  .evc-main-heading {
    font-size: 28px;
  }

  .evc-slide {
    flex-direction: column;
  }

  .evc-content,
  .evc-image {
    width: 100%;
  }

  .evc-image {
    height: 250px;
  }

  .evc-content {
    padding: 30px;
  }

}
</style>

<section class="evc-section">

  <!-- Main Heading -->
<div class="main-page-title text-center">
